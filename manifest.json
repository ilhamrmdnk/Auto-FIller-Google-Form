{
  "manifest_version": 3,
  "name": "Google Form AutoFill",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html"
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://docs.google.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/forms/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}   